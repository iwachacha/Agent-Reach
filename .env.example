# Agent Reach Configuration
# Copy to .env and fill in your values
# Or use: agent-reach configure

# GitHub token (optional, for higher rate limits)
# GITHUB_TOKEN=ghp_your_token_here
# GH_TOKEN=ghp_your_token_here

# Qiita token (optional)
# QIITA_TOKEN=your_qiita_token_here

# SearXNG instance URL (required only for the searxng channel)
# SEARXNG_BASE_URL=https://search.example.com

# Twitter/X cookies (required only for the twitter channel)
# TWITTER_AUTH_TOKEN=your_auth_token_here
# TWITTER_CT0=your_ct0_here

# Legacy aliases AUTH_TOKEN and CT0 are also supported, but prefer the
# TWITTER_* names above for new setups.
